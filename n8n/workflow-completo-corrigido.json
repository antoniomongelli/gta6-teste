      "name": "Parse conteúdo gerado",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-5296, 464],
      "parameters": {
        "jsCode": "const cls = $('Parse resposta OpenAI classificação').item.json;\nlet art;\ntry {\n  art = JSON.parse($input.item.json.choices[0].message.content);\n} catch(e) {\n  art = { titulo: cls.titulo_pt, resumo: cls.resumo_pt, resumo_ia: cls.resumo_ia, conteudo: cls.conteudo_original?.slice(0,1000)||'', slug: '' };\n}\n\nconst slugBase = (art.slug || art.titulo || 'noticia')\n  .toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g,'')\n  .replace(/[^a-z0-9\\s-]/g,'').trim().replace(/\\s+/g,'-').slice(0,55);\nconst slug = slugBase + '-' + Date.now().toString(36);\n\nconst imgs = [\n  'https://images.unsplash.com/photo-1542751371-adc38448a05e?w=800&q=80',\n  'https://images.unsplash.com/photo-1511512578047-dfb367046420?w=800&q=80',\n  'https://images.unsplash.com/photo-1560419015-7c427e8ae5ba?w=800&q=80',\n  'https://images.unsplash.com/photo-1477959858617-67f85cf4f1df?w=800&q=80'\n];\n\nlet host = 'Desconhecida';\ntry { host = new URL(cls.url_original).hostname.replace('www.',''); } catch(e){}\n\nreturn [{ json: {\n  slug, item_id: cls.item_id,\n  titulo:    art.titulo   || cls.titulo_pt,\n  resumo:    art.resumo   || cls.resumo_pt,\n  resumo_ia: art.resumo_ia || cls.resumo_ia,\n  conteudo:  art.conteudo || '',\n  categoria: cls.categoria,\n  fonte: host, fonte_url: cls.url_original,\n  imagem_url: imgs[Math.floor(Math.random()*imgs.length)],\n  destaque: cls.eh_breaking || false,\n  publicado: true,\n  agente_fonte: 'n8n-openai',\n  agente_url: cls.url_original,\n  agente_hash: cls.hash\n}}];"
      }
    },

