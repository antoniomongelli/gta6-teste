    },

    {
      "id": "buscar-fontes",
      "name": "Buscar fontes ativas",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-7248, 16],
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.SUPABASE_URL }}/rest/v1/agent_fontes",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey",        "value": "={{ $vars.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $vars.SUPABASE_SERVICE_KEY }}" }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "select", "value": "*" },
            { "name": "ativo",  "value": "eq.true" },
            { "name": "or",     "value": "(ultima_coleta.is.null,ultima_coleta.lt.{{ new Date(Date.now() - 25*60*1000).toISOString() }})" }
          ]
        },
        "options": {}
      }
    },

    {
      "id": "loop-fonte",
      "name": "Loop por fonte",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [-7040, 16],
      "parameters": { "batchSize": 1, "options": {} }
    },

    {
      "id": "switch-tipo",
      "name": "Tipo da fonte?",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [-6816, -16],
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.tipo }}", "rightValue": "rss", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "RSS"
            },
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.tipo }}", "rightValue": "reddit", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "Reddit"
            },
            {
              "conditions": { "conditions": [{ "leftValue": "={{ $json.tipo }}", "rightValue": "twitter", "operator": { "type": "string", "operation": "equals" } }], "combinator": "and" },
              "renameOutput": true, "outputKey": "Twitter"
            }
          ]
        },
        "options": {}
      }
    },

    {
      "id": "fetch-rss",
      "name": "Fetch RSS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-6592, -256],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.url }}",
        "options": { "response": { "response": { "responseFormat": "text" } }, "timeout": 15000 }
      }
    },

    {
      "id": "parse-xml",
      "name": "Parse XML RSS",
      "type": "n8n-nodes-base.xml",
      "typeVersion": 1,
      "position": [-6368, -256],
      "parameters": { "options": {} }
    },

    {
      "id": "extrair-rss",
      "name": "Extrair itens RSS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-6160, -256],
      "parameters": {
        "jsCode": "const fonte = $('Loop por fonte').item.json;\nconst fonteId   = fonte.id;\nconst fonteNome = fonte.nome;\nconst palavras  = fonte.palavras_chave || [];\n\nlet items = [];\ntry {\n  const feed = $input.item.json;\n  const channel = feed.rss?.channel?.[0] || feed.feed || {};\n  const rawItems = channel.item || channel.entry || [];\n  items = Array.isArray(rawItems) ? rawItems : [rawItems];\n} catch(e) { return []; }\n\nconst resultado = [];\nfor (const item of items.slice(0, 20)) {\n  const titulo    = (item.title?.[0] || item.title || '').toString();\n  const link      = item.link?.[0] || item.link || item.id?.[0] || '';\n  const descricao = (item.description?.[0] || item.summary?.[0] || item.content?.[0] || '').toString();\n  const dataStr   = item.pubDate?.[0] || item.updated?.[0] || new Date().toISOString();\n  const urlStr    = typeof link === 'string' ? link : (link?._?.toString() || '');\n\n  const textoCompleto = (titulo + ' ' + descricao).toLowerCase();\n  const relevante = palavras.length === 0 || palavras.some(p => textoCompleto.includes(p.toLowerCase()));\n  if (!relevante) continue;\n\n  let hash = 0;\n  const hashInput = urlStr || titulo;\n  for (let i = 0; i < hashInput.length; i++) {\n    hash = ((hash << 5) - hash) + hashInput.charCodeAt(i);\n    hash = hash & hash;\n  }\n  const hashStr = Math.abs(hash).toString(16).padStart(8,'0') + '_' + hashInput.slice(-20).replace(/[^a-z0-9]/gi,'');\n\n  resultado.push({ json: {\n    fonte_id: fonteId, fonte_nome: fonteNome,\n    titulo_original: titulo.slice(0, 500),\n    conteudo_original: descricao.slice(0, 5000),\n    url_original: urlStr, hash: hashStr, data_original: dataStr\n  }});\n}\nreturn resultado;"
      }
    },

    {
      "id": "fetch-reddit",
      "name": "Fetch Reddit JSON",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-6592, 0],
      "parameters": {
        "method": "GET",
        "url": "={{ $json.url }}",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "User-Agent", "value": "GTA6NewsBot/1.0 (by /u/gta6newsbr)" }] },
        "sendQuery": true,
        "queryParameters": { "parameters": [{ "name": "limit", "value": "25" }, { "name": "sort", "value": "new" }] },
        "options": { "timeout": 15000 }
      }
    },

    {
      "id": "extrair-reddit",
      "name": "Extrair posts Reddit",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-6368, 0],
      "parameters": {
        "jsCode": "const fonte = $('Loop por fonte').item.json;\nconst fonteId   = fonte.id;\nconst fonteNome = fonte.nome;\nconst palavras  = fonte.palavras_chave || [];\nconst ultimoId  = fonte.ultimo_item_id || '';\n\nconst posts = $input.item.json?.data?.children || [];\nconst resultado = [];\n\nfor (const post of posts) {\n  const d = post.data;\n  if (!d || d.name === ultimoId) continue;\n  if (d.ups < 10) continue;\n  const texto = (d.title + ' ' + (d.selftext || '')).toLowerCase();\n  const relevante = palavras.length === 0 || palavras.some(p => texto.includes(p.toLowerCase()));\n  if (!relevante) continue;\n  resultado.push({ json: {\n    fonte_id: fonteId, fonte_nome: fonteNome,\n    titulo_original: d.title.slice(0, 500),\n    conteudo_original: (d.selftext || d.url || '').slice(0, 5000),\n    url_original: `https://reddit.com${d.permalink}`,\n    hash: 'reddit_' + d.id,\n    reddit_id: d.name, reddit_ups: d.ups,\n    data_original: new Date(d.created_utc * 1000).toISOString()\n  }});\n}\nreturn resultado.slice(0, 10);"
      }
    },

    {
      "id": "fetch-twitter",
      "name": "Search Twitter/X via SerpAPI",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-6592, 160],
      "parameters": {
        "method": "GET",
        "url": "https://serpapi.com/search",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "engine",  "value": "google" },
            { "name": "q",       "value": "GTA 6 site:twitter.com OR site:x.com -filter:retweets" },
            { "name": "num",     "value": "10" },
            { "name": "tbs",     "value": "qdr:d" },
            { "name": "api_key", "value": "={{ $vars.SERPAPI_KEY }}" }
          ]
        },
        "options": {}
      }
    },

    {
      "id": "extrair-twitter",
      "name": "Extrair resultados Twitter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-6368, 160],
      "parameters": {
        "jsCode": "const fonte = $('Loop por fonte').item.json;\nconst results = $input.item.json?.organic_results || [];\nreturn results.slice(0, 8).map(r => ({ json: {\n  fonte_id: fonte.id, fonte_nome: fonte.nome,\n  titulo_original: r.title || '',\n  conteudo_original: r.snippet || '',\n  url_original: r.link || '',\n  hash: 'tw_' + (r.link || '').replace(/[^a-z0-9]/gi,'').slice(-30),\n  data_original: new Date().toISOString()\n}}));"
      }
    },

