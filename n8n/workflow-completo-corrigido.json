    {
      "id": "openai-classificar",
      "name": "OpenAI: Classificar relevância",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-6160, 480],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $vars.OPENAI_API_KEY }}" },
            { "name": "Content-Type",  "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify({ model: 'gpt-4o-mini', temperature: 0.2, response_format: { type: 'json_object' }, messages: [ { role: 'system', content: 'Você é um editor especialista em GTA 6 e Rockstar Games. Avalie se a notícia é relevante para um site PT-BR sobre GTA VI.\\n\\nRELEVANTE (score>0.6): qualquer notícia sobre GTA 6, Rockstar, Vice City, Lucia/Jason, Leonida, trailers, leaks, GTA Online, pré-venda, datas.\\nNÃO RELEVANTE (score<0.4): outros jogos, memes sem info, spam.\\n\\nCATEGORIAS: oficial, leak, rumor, trailer, analise, online, breaking\\n\\nResponda APENAS JSON válido:\\n{\"relevante\":true,\"score\":0.0,\"categoria\":\"categoria\",\"motivo_rejeicao\":null,\"titulo_pt\":\"titulo em PT-BR\",\"resumo_pt\":\"resumo 1-2 frases PT-BR\",\"resumo_ia\":\"máx 120 chars para caixa IA do site\",\"eh_breaking\":false}' }, { role: 'user', content: 'TÍTULO: ' + $json.titulo_original + '\\n\\nCONTEÚDO: ' + ($json.conteudo_original || '').slice(0, 2000) + '\\n\\nFONTE: ' + $json.url_original } ] }) }}",
        "options": { "timeout": 30000 }
      }
    },

    {
      "id": "parse-class",
      "name": "Parse resposta OpenAI classificação",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-5952, 480],
      "parameters": {
        "jsCode": "const item = $('Loop por item').item.json;\nlet gpt;\ntry {\n  const texto = $input.item.json.choices[0].message.content;\n  gpt = JSON.parse(texto);\n} catch(e) {\n  return [{ json: { item_id: item.id, relevante: false, score: 0, motivo_rejeicao: 'Erro parse: ' + e.message, ...item } }];\n}\nreturn [{ json: {\n  item_id: item.id, fonte_id: item.fonte_id, hash: item.hash,\n  url_original: item.url_original, titulo_original: item.titulo_original,\n  conteudo_original: item.conteudo_original,\n  relevante: gpt.relevante, score: gpt.score,\n  categoria: gpt.categoria || 'rumor',\n  motivo_rejeicao: gpt.motivo_rejeicao || null,\n  titulo_pt: gpt.titulo_pt || item.titulo_original,\n  resumo_pt: gpt.resumo_pt || '',\n  resumo_ia: gpt.resumo_ia || '',\n  eh_breaking: gpt.eh_breaking || false\n}}];"
      }
    },

